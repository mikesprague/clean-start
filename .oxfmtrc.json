{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "ignorePatterns": [
    ".devcontainer/**",
    ".git/**",
    ".github/**",
    ".history/**",
    ".vscode/**",
    ".wrangler/**",
    "build/**",
    "dist/**",
    "public/**",
    "node_modules/**",
    "types/**"
  ],
  "jsxSingleQuote": true,
  "printWidth": 80,
  "quoteProps": "preserve",
  "semi": true,
  "singleQuote": true,
  "sortImports": true,
  "sortPackageJson": false,
  "tabWidth": 2,
  "trailingComma": "es5",
  "useTabs": false
}
