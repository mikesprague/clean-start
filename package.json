{
  "name": "clean-start",
  "version": "0.45.0",
  "description": "Open source new tab extension",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">= 24.x",
    "npm": ">= 11.x"
  },
  "packageManager": "npm@11.18.0",
  "scripts": {
    "build:extension": "cross-env BUILD_TYPE=extension tsc && vite build",
    "build": "tsc && vite build",
    "changelog": "npx conventional-changelog -p conventionalcommits -n changelog.config.mjs -i CHANGELOG.md -s && git add CHANGELOG.md",
    "changelog:preview": "npx conventional-changelog -p conventionalcommits -n changelog.config.mjs -u --stdout -i /dev/null",
    "clean": "rm -rf ./build",
    "dev": "vite serve",
    "format": "npx oxfmt ./src",
    "format:check": "npx oxfmt --check ./src",
    "lint": "npx oxlint ./src",
    "postbuild:extension": "rm ./build/_headers ./build/_redirects ./src/index.html ./build/*.map && npm run zip",
    "postbuild": "rm ./src/index.html",
    "poststart": "npm run postbuild",
    "prebuild:extension": "npm run clean && cp ./src/extension.html ./src/index.html",
    "prebuild": "npm run clean && cp ./src/pwa.html ./src/index.html",
    "prestart": "npm run prebuild",
    "preview": "vite preview",
    "start": "cross-env NODE_ENV=development concurrently 'npm run build -- --watch' 'npm run wrangler-pages-dev'",
    "test": "echo \"Error: no test specified\" && exit 1",
    "typecheck": "tsc --noEmit",
    "version": "npm run changelog",
    "wrangler-pages-dev": "wrangler pages dev --live-reload true --local true ./build",
    "zip": "cd build && zip -r clean-start-extension.zip ./"
  },
  "keywords": [],
  "repository": {
    "url": "https://github.com/mikesprague/clean-start"
  },
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "homepage": "https://cleanstart.page",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mikesprague/clean-start/issues"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "7.3.0",
    "@fortawesome/free-brands-svg-icons": "7.3.0",
    "@fortawesome/free-solid-svg-icons": "7.3.0",
    "@fortawesome/react-fontawesome": "3.3.1",
    "@mantine/core": "9.4.1",
    "@mantine/hooks": "9.4.1",
    "@rwh/keystrokes": "1.5.6",
    "cheerio": "1.2.0",
    "dayjs": "1.11.21",
    "dompurify": "3.4.11",
    "he": "1.2.0",
    "jotai": "2.20.1",
    "nanoid": "5.1.16",
    "prop-types": "15.8.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/he": "1.2.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "autoprefixer": "10.5.2",
    "concurrently": "10.0.3",
    "conventional-changelog": "8.0.0",
    "conventional-changelog-conventionalcommits": "10.2.0",
    "cross-env": "10.1.0",
    "cssnano": "8.0.2",
    "cz-git": "1.13.1",
    "globals": "17.7.0",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "postcss": "8.5.16",
    "postcss-cli": "11.0.1",
    "postcss-preset-mantine": "1.18.0",
    "postcss-simple-vars": "7.0.1",
    "prop-types": "15.8.1",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vite-plugin-html": "3.2.2",
    "vite-plugin-pwa": "1.3.0",
    "wrangler": "4.105.0"
  },
  "overrides": {
    "glob": "^13.0.6"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "volta": {
    "node": "26.4.0",
    "npm": "11.18.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "fsevents@2.3.3": true,
    "workerd@1.20260625.1": true
  }
}
