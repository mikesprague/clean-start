{
  "name": "clean-start",
  "version": "0.43.0",
  "description": "Open source new tab extension",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">= 24.x",
    "npm": ">= 11.x"
  },
  "packageManager": "npm@11.12.0",
  "scripts": {
    "build:extension": "cross-env BUILD_TYPE=extension tsc && vite build",
    "build": "tsc && vite build",
    "changelog": "npx conventional-changelog -p conventionalcommits -n changelog.config.mjs -i CHANGELOG.md -s && git add CHANGELOG.md",
    "changelog:preview": "npx conventional-changelog -p conventionalcommits -n changelog.config.mjs -u --stdout -i /dev/null",
    "clean": "rm -rf ./build",
    "dev": "vite serve",
    "lint": "npm run lint:eslint",
    "lint:eslint": "npx eslint . --cache",
    "postbuild:extension": "rm ./build/_headers ./build/_redirects ./src/index.html ./build/*.map && npm run zip",
    "postbuild": "rm ./src/index.html",
    "poststart": "npm run postbuild",
    "prebuild:extension": "npm run clean && cp ./src/extension.html ./src/index.html",
    "prebuild": "npm run clean && npm install && cp ./src/pwa.html ./src/index.html",
    "prestart": "npm run prebuild",
    "prettier": "prettier --check \"**/*.{ts,tsx}\"",
    "preview": "vite preview",
    "start": "cross-env NODE_ENV=development concurrently 'npm run build -- --watch' 'npm run wrangler-pages-dev'",
    "test": "echo \"Error: no test specified\" && exit 1",
    "typecheck": "tsc --noEmit",
    "version": "npm run changelog",
    "wrangler-pages-dev": "wrangler pages dev --live-reload true --local true ./build",
    "zip": "cd build && zip -r clean-start-extension.zip ./"
  },
  "keywords": [],
  "repository": {
    "url": "https://github.com/mikesprague/clean-start"
  },
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "homepage": "https://cleanstart.page",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mikesprague/clean-start/issues"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "7.2.0",
    "@fortawesome/free-brands-svg-icons": "7.2.0",
    "@fortawesome/free-solid-svg-icons": "7.2.0",
    "@fortawesome/react-fontawesome": "3.3.0",
    "@mantine/core": "^9.0.0-alpha.6",
    "@mantine/hooks": "^9.0.0-alpha.6",
    "@rwh/keystrokes": "1.5.6",
    "cheerio": "1.2.0",
    "dayjs": "1.11.20",
    "dompurify": "3.3.3",
    "he": "1.2.0",
    "jotai": "2.18.1",
    "nanoid": "5.1.7",
    "prop-types": "15.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@eslint/js": "^10.0.1",
    "@types/dompurify": "3.2.0",
    "@types/he": "1.2.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.4.27",
    "concurrently": "9.2.1",
    "conventional-changelog": "7.2.0",
    "conventional-changelog-conventionalcommits": "9.3.0",
    "cross-env": "10.1.0",
    "cssnano": "7.1.3",
    "cz-git": "1.12.0",
    "eslint": "10.1.0",
    "eslint-config-mantine": "4.0.3",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "globals": "^17.4.0",
    "postcss": "8.5.8",
    "postcss-cli": "11.0.1",
    "postcss-preset-mantine": "1.18.0",
    "postcss-simple-vars": "7.0.1",
    "prettier": "3.8.1",
    "prop-types": "15.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "8.0.1",
    "vite-plugin-html": "3.2.2",
    "vite-plugin-pwa": "1.2.0",
    "wrangler": "4.77.0"
  },
  "overrides": {
    "@conventional-changelog/git-client": "^2.6.0",
    "@eslint/js": "^10.0.1",
    "eslint": "10.1.0",
    "flatted": "3.4.2",
    "glob": "^13.0.6",
    "serialize-javascript": "^7.0.4",
    "undici": "^7.24.5",
    "vite": "8.0.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "volta": {
    "node": "25.8.1",
    "npm": "11.12.0"
  }
}
